
<http://localhost:10214/container/queryContainer/zmMeDwULCJeqFZvwIWzAiOjcuzPSrlXUwpHrkfQh/context> {
  <http://localhost:10214/container/queryContainer/zmMeDwULCJeqFZvwIWzAiOjcuzPSrlXUwpHrkfQh>
    a <http://spinrdf.org/sp#Query>, <http://spinrdf.org/sp#Select>, <http://www.w3.org/ns/prov#Entity>,
      <http://www.w3.org/ns/ldp#Resource>;
    <http://www.w3.org/2000/01/rdf-schema#label> "test";
    <http://spinrdf.org/sp#text> """PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX sh: <http://www.w3.org/ns/shacl#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
SELECT DISTINCT ?attribute ?datatype ?ontology ?ontologyStatus ?ontologyVersion ?g WHERE {
  GRAPH ?g {
    ?nodeShape sh:targetClass <http://ontologies.metaphacts.com/test-1/Class1>;
      sh:property ?sh.
    ?sh sh:path ?attribute.
    OPTIONAL { ?sh sh:datatype ?datatype. }
    ?ontology rdf:type owl:Ontology.
    OPTIONAL { ?ontology <http://purl.org/ontology/bibo/status> ?ontologyStatus. }
    OPTIONAL { ?ontology owl:versionInfo ?ontologyVersion. }
    FILTER(ISIRI(?attribute))
    FILTER(NOT EXISTS { ?sh sh:class ?relationTarget. })
    FILTER(NOT EXISTS { ?sh sh:or ?list. })
    FILTER(NOT EXISTS {
      ?sh sh:node ?node.
      ?node (sh:or/(rdf:rest*)/rdf:first/sh:class) skos:Concept.
    })
    FILTER(?ontology != <http://ontologies.metaphacts.com/test-1/0.3>)
  }
}
ORDER BY (?attribute)""";
    <http://www.w3.org/ns/prov#wasAttributedTo> <http://www.metaphacts.com/resource/user/admin>;
    <http://www.w3.org/ns/prov#generatedAtTime> "2026-04-06T14:15:19.638Z"^^<http://www.w3.org/2001/XMLSchema#dateTime> .
  
  <http://www.metaphacts.com/ontologies/platform#queryContainer> <http://www.w3.org/ns/ldp#contains>
      <http://localhost:10214/container/queryContainer/zmMeDwULCJeqFZvwIWzAiOjcuzPSrlXUwpHrkfQh> .
}
